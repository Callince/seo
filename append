[Unit]Description=Gunicorn for seodada.com Flask appAfter=network.target[Service]User=ec2-userGroup=ec2-userWorkingDirectory=/home/ec2-user/seo-web-analyzerEnvironmentFile=/etc/seodada.env# Flask EnvironmentEnvironment="FLASK_ENV=production"# Email Configuration - SMTP Only (support@seodada.com and payment@seodada.com)Environment="MAIL_SERVER=smtp.gmail.com"Environment="MAIL_PORT=587"Environment="MAIL_USE_TLS=True"Environment="MAIL_USE_SSL=False"# Support Email (support@seodada.com) - for verification, password reset, contact formEnvironment="MAIL_USERNAME=support@seodada.com"Environment="MAIL_PASSWORD='okwfchfsgppufztj'"Environment="MAIL_DEFAULT_SENDER=support@seodada.com"# Payment Email (payment@seodada.com) - for payment confirmations, subscription expiryEnvironment="MAIL_PAYMENT_USERNAME=payment@seodada.com"Environment="MAIL_PAYMENT_PASSWORD='axdjkwgfkcfhqlfj'"Environment="MAIL_PAYMENT_SENDER=payment@seodada.com"# Gmail API - DISABLED (using SMTP only)Environment="USE_GMAIL_API=False"# Display and Chrome settingsEnvironment="DISPLAY=:99"Environment="CHROME_BIN=/usr/bin/google-chrome"Environment="CHROME_PATH=/usr/bin/google-chrome"# Database ConfigurationEnvironment="DB_USERNAME=flaskuser"Environment="DB_PASSWORD=MyStrongPassword123"Environment="DB_HOST=127.0.0.1"Environment="DB_PORT=5432"Environment="DB_NAME=flaskdb"# Redis ConfigurationEnvironment="REDIS_HOST=127.0.0.1"Environment="REDIS_PORT=6379"# Razorpay Configuration (production keys)Environment="RAZORPAY_KEY_ID=rzp_live_RcO4xIW6L4A8Kh"Environment="RAZORPAY_KEY_SECRET=pnOmfnCRpG9rP1JXe6dBlGWV"# Gunicorn CommandExecStart=/home/ec2-user/seo-web-analyzer/venv/bin/gunicorn -w 4 -b 0.0.0.0:5000 --timeout 600 --graceful-timeout 600 --keep-alive 5 --max-requests 1000 --max-requests-jitter 100 app:appRestart=alwaysRestartSec=5TimeoutStopSec=600[Install]WantedBy=multi-user.target