# ============================================
# PRODUCTION ENVIRONMENT - DigitalOcean
# Copy this to .env and fill in real values
# ============================================

# FLASK
FLASK_ENV=production
SECRET_KEY=GENERATE_A_64_CHAR_RANDOM_STRING_HERE

# DATABASE (DigitalOcean Managed PostgreSQL)
# Option A: Use DATABASE_URL (preferred on App Platform - auto-injected)
# DATABASE_URL=postgresql://doadmin:PASSWORD@host:25060/defaultdb?sslmode=require
# Option B: Use individual vars (for Droplet deployment)
DB_USERNAME=doadmin
DB_PASSWORD=YOUR_DB_PASSWORD
DB_HOST=YOUR_DB_HOST.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=defaultdb
DB_SSLMODE=require

# EMAIL/SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_SUPPORT_USERNAME=support@seodada.com
MAIL_SUPPORT_PASSWORD=YOUR_APP_PASSWORD
MAIL_SUPPORT_SENDER=support@seodada.com
MAIL_PAYMENT_USERNAME=payment@seodada.com
MAIL_PAYMENT_PASSWORD=YOUR_APP_PASSWORD
MAIL_PAYMENT_SENDER=payment@seodada.com
USE_GMAIL_API=False

# REDIS (optional - set if using DO Managed Redis)
# REDIS_URL=rediss://default:PASSWORD@host:25061

# RAZORPAY
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# RECAPTCHA
RECAPTCHA_SITE_KEY=YOUR_SITE_KEY
RECAPTCHA_SECRET_KEY=YOUR_SECRET_KEY

# SECURITY
CRON_SECRET=GENERATE_RANDOM_STRING
SUPER_ADMIN_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# SITE
SITE_URL=https://seodada.com
